{
  "name": "@winstonfassett/webdev-vite",
  "version": "0.1.1-alpha.1",
  "description": "Vite plugin for webdev — live browser observability for AI agents",
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./devtools-element-grab": {
      "types": "./dist/devtools-element-grab.d.ts",
      "import": "./dist/devtools-element-grab.js"
    },
    "./storybook": {
      "types": "./dist/storybook/preset.d.ts",
      "import": "./dist/storybook/preset.js",
      "require": "./dist/storybook/preset.cjs",
      "default": "./dist/storybook/preset.js"
    },
    "./storybook/preset": {
      "types": "./dist/storybook/preset.d.ts",
      "import": "./dist/storybook/preset.js",
      "require": "./dist/storybook/preset.cjs",
      "default": "./dist/storybook/preset.cjs"
    },
    "./storybook/preview": {
      "types": "./dist/storybook/preview.d.ts",
      "import": "./dist/storybook/preview.js",
      "require": "./dist/storybook/preview.cjs",
      "default": "./dist/storybook/preview.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && cp src/storybook/*.cjs dist/storybook/"
  },
  "keywords": [
    "vite",
    "mcp",
    "ai",
    "devtools",
    "webdev"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WinstonFassett/webdev-ai.git",
    "directory": "packages/adapter-vite"
  },
  "homepage": "https://github.com/WinstonFassett/webdev",
  "bugs": {
    "url": "https://github.com/WinstonFassett/webdev/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@winstonfassett/webdev-gateway": ">=0.1.0-alpha.0"
  },
  "peerDependencies": {
    "vite": ">=6.0.0",
    "@vitejs/devtools-kit": "*"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": false
    },
    "@vitejs/devtools-kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@winstonfassett/webdev-gateway": "file:../../apps/gateway",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitejs/devtools-kit": "^0.1.24",
    "typescript": "^5.8.0",
    "vite": "^8.0.0"
  }
}
