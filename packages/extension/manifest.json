{
  "manifest_version": 3,
  "name": "web-dev-mcp",
  "version": "0.1.0",
  "description": "Auto-attach CDP to dev server pages for AI agent browser control",
  "permissions": [
    "debugger",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://*.localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*",
    "https://*.localhost/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://*.localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*",
        "https://*.localhost/*",
        "https://127.0.0.1/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
