{
  "name": "@winstonfassett/web-dev-mcp-nextjs",
  "version": "0.1.0",
  "description": "Next.js adapter for web-dev-mcp — live browser observability for AI agents",
  "type": "module",
  "engines": { "node": ">=20.6.0" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./init": {
      "types": "./dist/init.d.ts",
      "import": "./dist/init.js",
      "require": "./dist/init.js"
    },
    "./instrument": {
      "types": "./dist/instrument.d.ts",
      "import": "./dist/instrument.js",
      "require": "./dist/instrument.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc"
  },
  "keywords": [
    "nextjs",
    "mcp",
    "ai",
    "devtools",
    "web-dev-mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WinstonFassett/web-dev-mcp.git",
    "directory": "packages/adapter-nextjs"
  },
  "homepage": "https://github.com/WinstonFassett/web-dev-mcp",
  "bugs": { "url": "https://github.com/WinstonFassett/web-dev-mcp/issues" },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@winstonfassett/web-dev-mcp-gateway": "^0.1.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    }
  },
  "devDependencies": {
    "@winstonfassett/web-dev-mcp-gateway": "file:../gateway",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.0"
  }
}
