{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "zod": ["./node_modules/zod/index.d.ts"],
      "zod/v3": ["./node_modules/zod/v3/index.d.ts"],
      "zod/v4": ["./node_modules/zod/v4/index.d.ts"],
      "zod/v4/core": ["./node_modules/zod/v4/core/index.d.ts"],
      "zod/*": ["./node_modules/zod/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/client/**"]
}
